# ============================================
# Alfred Project — Production Environment Template
# Copy to .env.prod and fill in your values
# ============================================

# ── General ───────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
COMPOSE_PROJECT_NAME=alfred
VERSION=latest

# ── PostgreSQL (shared instance, separate databases) ──────────────────────────
POSTGRES_USER=alfred
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_PORT=5432

# Per-service database names (auto-created by init-databases.sh)
IDENTITY_DB_NAME=alfred_identity
CORE_DB_NAME=alfred_core
NOTIFICATION_DB_NAME=alfred_notification

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME>

# ── URLs & Routing ────────────────────────────────────────────────────────────
GATEWAY_URL=https://gateway.test
GATEWAY_PORT=8000

# Frontend URLs (comma-separated for CORS)
FRONTEND_URL=https://sso.test,https://core.test

# SSO / Identity Web
SSO_WEB_URL=https://sso.test
SSO_WEB_PORT=3100

# Core / App Web
CORE_WEB_URL=https://core.test
CORE_WEB_PORT=3200

# ── JWT / OAuth2 ──────────────────────────────────────────────────────────────
JWT_AUDIENCE=alfred-ecosystem
SSO_COOKIE_DOMAIN=gateway.test

# SSO Web OIDC
SSO_OIDC_CLIENT_ID=sso_web
SSO_OIDC_CLIENT_SECRET=<CHANGE_ME>
SSO_NEXTAUTH_SECRET=<RANDOM_SECRET>

# Core Web OIDC
CORE_OIDC_CLIENT_ID=core_web
CORE_OIDC_CLIENT_SECRET=<CHANGE_ME>
CORE_NEXTAUTH_SECRET=<RANDOM_SECRET>

# ── mTLS (Service-to-Service) ────────────────────────────────────────────────
MTLS_ENABLED=true
MTLS_SERVER_CERT_PASSWORD=

# ── Cloudflare R2 Storage (alfred-core) ───────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=alfred
CF_API_TOKEN=

# ── SMTP (alfred-notification) ───────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME="Alfred Identity"