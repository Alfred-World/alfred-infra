# ============================================
# Alfred Project — Production Environment Template
# Copy to .env.prod and fill in your values
# ============================================

# ── [Optional] General ────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
COMPOSE_PROJECT_NAME=alfred
VERSION=latest

# ── [Required] PostgreSQL (shared instance, separate databases) ──────────────
POSTGRES_USER=alfred
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_PORT=5432

# Per-service database names (auto-created by init-databases.sh)
IDENTITY_DB_NAME=alfred_identity
CORE_DB_NAME=alfred_core
NOTIFICATION_DB_NAME=alfred_notification

# ── [Required] Redis ──────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME>

# ── [Required] URLs & Routing ─────────────────────────────────────────────────
GATEWAY_URL=https://gateway.lucasvu.io.vn
GATEWAY_PORT=8000

# Frontend URLs (comma-separated for CORS)
FRONTEND_URL=https://sso.lucasvu.io.vn,https://app.lucasvu.io.vn

# SSO / Identity Web
SSO_WEB_URL=https://sso.lucasvu.io.vn
SSO_WEB_PORT=7100

# Identity Web URL (used by identity service for password reset links etc.)
IDENTITY_WEB_URL=https://sso.lucasvu.io.vn

# Core / App Web
CORE_WEB_URL=https://app.lucasvu.io.vn
CORE_WEB_PORT=7200

# ── [Required] JWT / OAuth2 ───────────────────────────────────────────────────
JWT_AUDIENCE=alfred-ecosystem
# JWT_ISSUER MUST match AUTH_VALID_ISSUER on gateway — mismatch = 401 on all API calls
JWT_ISSUER=$GATEWAY_URL
JWT_AUDIENCE=alfred-ecosystem
# SSO_COOKIE_DOMAIN must match the apex domain of your gateway URL
# e.g. if GATEWAY_URL=https://gateway.lucasvu.io.vn, set SSO_COOKIE_DOMAIN=lucasvu.io.vn
SSO_COOKIE_DOMAIN=<YOUR_APEX_DOMAIN>

# SSO Web OIDC
SSO_OIDC_CLIENT_ID=sso_web
SSO_OIDC_CLIENT_SECRET=<CHANGE_ME>
SSO_NEXTAUTH_SECRET=<RANDOM_SECRET>

# Core Web OIDC
CORE_OIDC_CLIENT_ID=core_web
CORE_OIDC_CLIENT_SECRET=<CHANGE_ME>
CORE_NEXTAUTH_SECRET=<RANDOM_SECRET>

# ── [Optional] mTLS (Service-to-Service) ─────────────────────────────────────
# NOTE: Disabled by default. Nginx handles external TLS. Internal Docker communication is secure.
MTLS_ENABLED=true
MTLS_SERVER_CERT_PASSWORD=

# ── [Required] Cloudflare R2 Storage (alfred-core) ───────────────────────────
R2_ACCOUNT_ID=<CHANGE_ME>
R2_ACCESS_KEY_ID=<CHANGE_ME>
R2_SECRET_ACCESS_KEY=<CHANGE_ME>
R2_BUCKET_NAME=alfred
CF_API_TOKEN=<CHANGE_ME>

# ── [Required] SMTP (alfred-notification) ────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=<CHANGE_ME>
SMTP_PASSWORD=<CHANGE_ME>
SMTP_FROM_EMAIL=noreply@lucasvu.io.vn
SMTP_FROM_NAME="Alfred Identity"