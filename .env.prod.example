# ============================================
# Alfred Project — Production Environment Template
# Copy to .env.prod and fill in your values
# ============================================

# ── General ───────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
COMPOSE_PROJECT_NAME=alfred
VERSION=latest

# ── PostgreSQL (shared instance, separate databases) ──────────────────────────
POSTGRES_USER=alfred
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_PORT=5432

# Per-service database names
IDENTITY_DB_NAME=alfred_identity
CORE_DB_NAME=alfred_core
NOTIFICATION_DB_NAME=alfred_notification

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME>

# ── URLs ──────────────────────────────────────────────────────────────────────
GATEWAY_URL=https://gateway.lucasvu.io.vn
# SSO_WEB_URL: OIDC redirect URIs, CORS origins, NextAuth callbacks, and email links (password-reset / email-verify)
SSO_WEB_URL=https://sso.lucasvu.io.vn
CORE_WEB_URL=https://app.lucasvu.io.vn

# ── Ports ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=8000
SSO_WEB_PORT=7100
CORE_WEB_PORT=7200

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_AUDIENCE=alfred-ecosystem
# JWT_ISSUER MUST match AUTH_VALID_ISSUER on gateway — mismatch = 401 on all API calls
JWT_ISSUER=$GATEWAY_URL
# SSO_COOKIE_DOMAIN must match the apex domain of GATEWAY_URL
# e.g. if GATEWAY_URL=https://gateway.lucasvu.io.vn → SSO_COOKIE_DOMAIN=lucasvu.io.vn
SSO_COOKIE_DOMAIN=<YOUR_APEX_DOMAIN>

APP_SECRET_KEY=<CHANGE_ME_use_a_strong_random_secret>

# Frontend URLs (comma-separated, used for CORS allowlist)
FRONTEND_URL=https://sso.lucasvu.io.vn,https://app.lucasvu.io.vn

# ── Frontend Auth (NextAuth + OIDC) ───────────────────────────────────────────
SSO_NEXTAUTH_SECRET=<RANDOM_SECRET>
SSO_OIDC_CLIENT_ID=sso_web
SSO_OIDC_CLIENT_SECRET=<CHANGE_ME>
CORE_NEXTAUTH_SECRET=<RANDOM_SECRET>
CORE_OIDC_CLIENT_ID=core_web
CORE_OIDC_CLIENT_SECRET=<CHANGE_ME>

# ── mTLS (Service-to-Service) ─────────────────────────────────────────────────
# NOTE: Nginx handles external TLS. mTLS secures internal service-to-service traffic.
MTLS_ENABLED=true
MTLS_SERVER_CERT_PASSWORD=

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=<CHANGE_ME>
SMTP_PASSWORD=<CHANGE_ME>
SMTP_FROM_EMAIL=noreply@lucasvu.io.vn
SMTP_FROM_NAME="Alfred Notification"

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=<CHANGE_ME>
R2_ACCESS_KEY_ID=<CHANGE_ME>
R2_SECRET_ACCESS_KEY=<CHANGE_ME>
R2_BUCKET_NAME=alfred
CF_API_TOKEN=<CHANGE_ME>

# ── Groq AI ───────────────────────────────────────────────────────────────────
GROQ_API_KEYS=gsk_key1,gsk_key2
GROQ_DEFAULT_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
GROQ_VISION_MODELS=meta-llama/llama-4-scout-17b-16e-instruct

# ── Redis Streams ─────────────────────────────────────────────────────────────
IDENTITY_USER_STREAM_KEY=identity:user-events