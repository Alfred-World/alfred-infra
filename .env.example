# ============================================
# Alfred Project — Development Environment Template
# Copy to .env and update values
# ============================================

# ── General ───────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
COMPOSE_PROJECT_NAME=alfred
VERSION=latest

# ── PostgreSQL (shared instance, separate databases) ──────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Admin@123
POSTGRES_PORT=5432

# Per-service database names
IDENTITY_DB_NAME=alfred_identity
CORE_DB_NAME=alfred_core
NOTIFICATION_DB_NAME=alfred_notification

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=Admin@123

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
