# ============================================
# Alfred Project — Development Environment Template
# Copy to .env and update values
# ============================================

# ── General ───────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
COMPOSE_PROJECT_NAME=alfred
VERSION=latest

# ── PostgreSQL (shared instance, separate databases) ──────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Admin@123
POSTGRES_PORT=5432

# Per-service database names
IDENTITY_DB_NAME=alfred_identity
CORE_DB_NAME=alfred_core
NOTIFICATION_DB_NAME=alfred_notification

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=Admin@123

# ── URLs ──────────────────────────────────────────────────────────────────────
GATEWAY_URL=https://gateway.yourdomain.com
# SSO_WEB_URL: OIDC redirect URIs, CORS origins, NextAuth callbacks, and email links (password-reset / email-verify)
SSO_WEB_URL=https://sso.yourdomain.com
CORE_WEB_URL=https://core.yourdomain.com

# ── Ports ─────────────────────────────────────────────────────────────────────
GATEWAY_PORT=8000
SSO_WEB_PORT=7100
CORE_WEB_PORT=7200

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_AUDIENCE=alfred-ecosystem
SSO_COOKIE_DOMAIN=yourdomain.com
APP_SECRET_KEY=<CHANGE_ME_use_a_strong_random_secret>

# Frontend URLs (comma-separated, used for CORS allowlist)
FRONTEND_URL=https://sso.yourdomain.com,https://core.yourdomain.com

# ── Frontend Auth (NextAuth + OIDC) ───────────────────────────────────────────
SSO_NEXTAUTH_SECRET=<CHANGE_ME>
SSO_OIDC_CLIENT_ID=sso_web
SSO_OIDC_CLIENT_SECRET=<CHANGE_ME>
CORE_NEXTAUTH_SECRET=<CHANGE_ME>
CORE_OIDC_CLIENT_ID=core_web
CORE_OIDC_CLIENT_SECRET=<CHANGE_ME>

# ── mTLS ──────────────────────────────────────────────────────────────────────
MTLS_ENABLED=false
MTLS_SERVER_CERT_PASSWORD=

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=<CHANGE_ME>
SMTP_PASSWORD=<CHANGE_ME>
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Alfred Notification

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=<CHANGE_ME>
R2_ACCESS_KEY_ID=<CHANGE_ME>
R2_SECRET_ACCESS_KEY=<CHANGE_ME>
R2_BUCKET_NAME=alfred
CF_API_TOKEN=<CHANGE_ME>

# ── Groq AI ───────────────────────────────────────────────────────────────────
GROQ_API_KEYS=gsk_key1,gsk_key2
GROQ_DEFAULT_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
GROQ_VISION_MODELS=meta-llama/llama-4-scout-17b-16e-instruct

# ── Redis Streams ─────────────────────────────────────────────────────────────
IDENTITY_USER_STREAM_KEY=identity:user-events
